{
  "name": "sonaerp",
  "version": "5.0.0",
  "description": "SonaERP v5.0 - Digital Procurement & Contract Management Platform for Sonatrach",
  "private": true,
  "workspaces": [
    "server",
    "client",
    "shared"
  ],
  "scripts": {
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build:server": "cd server && npm run build",
    "build:client": "cd client && npm run build",
    "prisma:generate": "npx prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "npx prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:seed": "cd server && npm run seed",
    "db:reset": "npx prisma migrate reset --schema=prisma/schema.prisma"
  },
  "devDependencies": {
    "prisma": "^5.8.0"
  }
}
